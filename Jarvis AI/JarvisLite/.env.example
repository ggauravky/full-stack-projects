# JarvisLite API Keys
# Rename this file to .env and fill in your keys

# AI Provider (choose 'openai' or 'gemini')
AI_PROVIDER=gemini

# Option 1: Gemini API Key (Get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: OpenAI API Key (Get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Assistant settings
ASSISTANT_NAME=JarvisLite
SPEECH_RATE=175
